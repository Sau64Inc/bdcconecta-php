{
    "name": "bdcconecta/php-sdk",
    "description": "PHP SDK para BDC Conecta Banking API",
    "type": "library",
    "license": "MIT",
    "keywords": ["banking", "api", "bdc", "conecta", "payments", "transfers"],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "BDCConecta\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BDCConecta\\Tests\\": "tests/"
        }
    }
}
